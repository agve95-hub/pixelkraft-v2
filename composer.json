{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "pixelkraft/pixelkraft",
    "type": "project",
    "description": "Self-hosted Git-to-Render site operations platform (Laravel + Livewire).",
    "keywords": [
        "pixelkraft",
        "laravel",
        "livewire",
        "deployment",
        "git",
        "hosting"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.0",
        "czproject/git-php": "^4.6",
        "google/analytics-data": "^0.22",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/fortify": "^1.36",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.32",
        "livewire/flux": "^2.13",
        "livewire/livewire": "^4.2",
        "sentry/sentry-laravel": "^4.0",
        "spatie/laravel-backup": "^10.0",
        "symfony/css-selector": "^7.4",
        "symfony/dom-crawler": "^7.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@ensure-env",
            "@ensure-db",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "@ensure-env",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan test"
        ],
        "phpstan": [
            "phpstan analyse -c phpstan.neon.dist --memory-limit=512M"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "ensure-env": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"\\$env = @file_get_contents('.env') ?: ''; if (!preg_match('/^APP_KEY=.+$/m', \\$env)) { passthru('php artisan key:generate --ansi --force'); }\""
        ],
        "ensure-db": [
            "@php -r \"\\$env = @file_get_contents('.env') ?: ''; preg_match('/^DB_CONNECTION=(.+)$/m', \\$env, \\$m); \\$conn = trim(\\$m[1] ?? ''); if (\\$conn === 'sqlite') { if (!is_dir('database')) mkdir('database', 0755, true); if (!file_exists('database/database.sqlite')) touch('database/database.sqlite'); }\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
