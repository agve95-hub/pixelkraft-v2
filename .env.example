APP_NAME=pixelkraft
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Database (MariaDB) ─────────────────────────
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pixelkraft
DB_USERNAME=pixelkraft
DB_PASSWORD=

# ─── Redis ───────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Queue / Cache / Session (local-safe defaults) ─
QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file
# Production: set to true so the session cookie is only sent over HTTPS.
# SESSION_SECURE_COOKIE=true

# ─── GitHub ──────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_REQUIRE_SIGNATURE=true
# Optional: comma-separated extra git hosts allowed in repo URLs (beyond github.com, gitlab.com, bitbucket.org)
# ALLOWED_GIT_HOSTS=git.mycompany.com

# ─── Cloudflare R2 (S3-compatible) ───────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pixelkraft-media
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_URL=https://media.yourdomain.com

# ─── Cloudflare Analytics ────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Google Analytics ────────────────────────────
GOOGLE_ANALYTICS_CREDENTIALS_PATH=storage/app/google-credentials.json

# ─── PageSpeed Insights ──────────────────────────
# Optional. Without a key the free tier allows ~25 req/100s (enough for < 25 sites).
# Enable "PageSpeed Insights API" in Google Cloud Console to get a key.
PSI_API_KEY=
# Optional: mark HTTP checks slower than this (ms) as degraded (yellow) if still 2xx
UPTIME_DEGRADED_AFTER_MS=3000

# ─── Google Search Console ───────────────────────
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_PATH=storage/app/google-credentials.json

# ─── Resend (Email) ─────────────────────────────
RESEND_API_KEY=
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="pixelkraft"

# Required in production: Bearer token for POST /api/inbox/{site-slug}.
# Must be at least 32 characters. Leave empty only in local dev (enforcement is
# automatically enabled in non-local environments via INBOX_INBOUND_REQUIRE_SECRET).
INBOX_INBOUND_SECRET=
# INBOX_INBOUND_REQUIRE_SECRET=true   # uncomment to force enforcement in local dev

# ─── Discord Notifications ───────────────────────
DISCORD_WEBHOOK_URL=

# ─── Paths ───────────────────────────────────────
REPOS_PATH=/var/www/pixelkraft/repos
SITES_DEPLOY_PATH=/var/www/sites
NGINX_SITES_PATH=/etc/nginx/sites-available

# ─── Backups ─────────────────────────────────────
BACKUP_DISK=r2

# ─── Horizon ─────────────────────────────────────
HORIZON_PREFIX=pixelkraft_horizon:

# ─── API Token Expiration ────────────────────────
# Minutes until Sanctum API tokens expire. Leave blank for no expiration.
# Recommended: 525600 (1 year) for long-lived tokens, 43200 (30 days) for short-lived.
SANCTUM_TOKEN_EXPIRATION=

# ─── Data Retention ──────────────────────────────
# Days to keep uptime check records (pruned weekly by pixelkraft:prune-monitoring).
UPTIME_RETENTION_DAYS=30
# Days to keep raw analytics event records.
EVENTS_RETENTION_DAYS=90
# Days to keep webhook_deliveries audit rows (pruned weekly by pixelkraft:prune-webhooks).
WEBHOOK_DELIVERIES_RETENTION_DAYS=30

# ─── Error Tracking (Sentry) ────────────────────
# Install with: composer require sentry/sentry-laravel
# Leave empty to disable. Get your DSN from sentry.io → Settings → Client Keys.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05   # 5% of requests traced (adjust per plan quota)
# SENTRY_RELEASE=                  # git SHA or app version — auto-tagged on events

# ─── Logging ─────────────────────────────────────
# Production recommendation: LOG_STACK=daily,stderr + LOG_STDERR_FORMATTER=json
# to emit structured JSON logs to stdout for log aggregators (Datadog, Loki, etc.).
# LOG_STACK=single
# LOG_STDERR_FORMATTER=json
