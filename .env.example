APP_NAME=Platform
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# ─── Database (MariaDB) ─────────────────────────
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Platform
DB_USERNAME=Platform
DB_PASSWORD=

# ─── Redis ───────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Queue / Cache / Session (local-safe defaults) ─
QUEUE_CONNECTION=redis
CACHE_STORE=file
SESSION_DRIVER=file
# Production: set to true so the session cookie is only sent over HTTPS.
# SESSION_SECURE_COOKIE=true

# ─── Registration ───────────────────────────────
# Open sign-up is disabled by default. Enable only during initial setup or onboarding.
REGISTRATION_ENABLED=false

# ─── GitHub ──────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_REQUIRE_SIGNATURE=true
# Optional: comma-separated extra git hosts allowed in repo URLs (beyond github.com, gitlab.com, bitbucket.org)
# ALLOWED_GIT_HOSTS=git.mycompany.com

# ─── Cloudflare R2 (S3-compatible) ───────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=Platform-media
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_URL=https://media.yourdomain.com

# ─── Cloudflare Analytics ────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Google Analytics ────────────────────────────
# Store the service account JSON in storage/app/private/ (not web-accessible).
# Also add `location ~* \.json$ { deny all; }` to your Nginx config as extra protection.
GOOGLE_ANALYTICS_CREDENTIALS_PATH=storage/app/private/google-credentials.json

# ─── PageSpeed Insights ──────────────────────────
# Optional. Without a key the free tier allows ~25 req/100s (enough for < 25 sites).
# Enable "PageSpeed Insights API" in Google Cloud Console to get a key.
PSI_API_KEY=
# Optional: mark HTTP checks slower than this (ms) as degraded (yellow) if still 2xx
UPTIME_DEGRADED_AFTER_MS=3000

# ─── Google Search Console ───────────────────────
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_PATH=storage/app/private/google-credentials.json

# ─── Email ───────────────────────────────────────
# Primary: Resend (used for newsletter campaigns via SendCampaigns command)
RESEND_API_KEY=
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="Platform"
# Alternatives (uncomment and set MAIL_MAILER accordingly):
# POSTMARK_API_KEY=
# AWS_ACCESS_KEY_ID=       # SES
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Required in production: Bearer token for POST /api/inbox/{site-slug}.
# Must be at least 32 characters. Leave empty only in local dev (enforcement is
# automatically enabled in non-local environments via INBOX_INBOUND_REQUIRE_SECRET).
INBOX_INBOUND_SECRET=
# INBOX_INBOUND_REQUIRE_SECRET=true   # uncomment to force enforcement in local dev

# ─── Notifications ───────────────────────────────
DISCORD_WEBHOOK_URL=
# Optional Slack integration (requires slack/slack-laravel package or similar):
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=#Platform-alerts

# ─── Runtime Site Process Supervision ───────────
# Set to true to have Platform write a Supervisor config on every runtime deploy
# so Node.js processes survive server reboots. Requires supervisord + write access
# to SUPERVISOR_CONF_PATH by the web server user.
SITE_RUNTIME_SUPERVISOR_ENABLED=false
SUPERVISOR_CONF_PATH=/etc/supervisor/conf.d

# ─── Runtime Site Configuration ─────────────────
# These control how Node.js runtime deployments are managed.
# Defaults are suitable for local dev; override in production.
# SITE_RUNTIME_HOST=127.0.0.1
# SITE_RUNTIME_PORT_START=4100          # First port in the allocation range
# SITE_RUNTIME_PORT_SPAN=2000           # Number of ports available (4100–6099)
# SITE_RUNTIME_STARTUP_TIMEOUT_SECONDS=30
# SITE_RUNTIME_STORAGE_PATH=/var/www/Platform/runtime-sites
# SITE_RUNTIME_PID_PATH=/var/www/Platform/runtime-pids
# SITE_RUNTIME_LOG_PATH=/var/log/Platform/runtime-sites

# ─── Paths ───────────────────────────────────────
REPOS_PATH=/var/www/Platform/repos
SITES_DEPLOY_PATH=/var/www/sites
NGINX_SITES_PATH=/etc/nginx/sites-available

# ─── Backups ─────────────────────────────────────
BACKUP_DISK=r2

# ─── Horizon ─────────────────────────────────────
HORIZON_PREFIX=Platform_horizon:

# ─── API Token Expiration ────────────────────────
# Minutes until Sanctum API tokens expire. Leave blank for no expiration.
# Recommended: 525600 (1 year) for long-lived tokens, 43200 (30 days) for short-lived.
SANCTUM_TOKEN_EXPIRATION=

# ─── Data Retention ──────────────────────────────
# Days to keep uptime check records (pruned weekly by platform:prune-monitoring).
UPTIME_RETENTION_DAYS=30
# Days to keep raw analytics event records.
EVENTS_RETENTION_DAYS=90
# Days to keep webhook_deliveries audit rows (pruned weekly by platform:prune-webhooks).
WEBHOOK_DELIVERIES_RETENTION_DAYS=30

# ─── Error Tracking (Sentry) ────────────────────
# Install with: composer require sentry/sentry-laravel
# Leave empty to disable. Get your DSN from sentry.io → Settings → Client Keys.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05   # 5% of requests traced (adjust per plan quota)
# SENTRY_RELEASE=                  # git SHA or app version — auto-tagged on events

# ─── Logging ─────────────────────────────────────
# Production recommendation: LOG_STACK=daily,stderr + LOG_STDERR_FORMATTER=json
# to emit structured JSON logs to stdout for log aggregators (Datadog, Loki, etc.).
# LOG_STACK=single
# LOG_STDERR_FORMATTER=json
